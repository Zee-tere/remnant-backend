# Remnant backend environment
# Copy to .env for local development. In AWS Lambda, store production values
# under /remnant/prod/* in SSM Parameter Store and inject them at deploy time.

NODE_ENV=development
APP_NAME=Remnant
PORT=3001

# Supabase PostgreSQL.
# Runtime uses the shared transaction-mode pooler on port 6543.
# Prisma migrations use DIRECT_URL via the shared session-mode pooler on port 5432.
# The direct database host below is only usable from IPv6 networks or with Supabase's IPv4 add-on:
# postgresql://postgres:[YOUR-PASSWORD]@db.vcgurglczberpgwwgrcf.supabase.co:5432/postgres
DATABASE_URL="postgresql://postgres.vcgurglczberpgwwgrcf:[YOUR-PASSWORD]@aws-1-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.vcgurglczberpgwwgrcf:[YOUR-PASSWORD]@aws-1-us-east-1.pooler.supabase.com:5432/postgres"

# Public frontend URL and optional comma-separated extra origins.
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://remnantmarket.co,https://www.remnantmarket.co

# Cognito.
COGNITO_USER_POOL_ID=us-east-1_REPLACE_ME
COGNITO_CLIENT_ID=REPLACE_WITH_COGNITO_APP_CLIENT_ID
COGNITO_HOSTED_UI_DOMAIN=https://your-domain.auth.us-east-1.amazoncognito.com

# Supabase Realtime bridge.
SUPABASE_URL=https://xxxxxx.supabase.co
SUPABASE_ANON_KEY=REPLACE_WITH_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=REPLACE_WITH_SUPABASE_SERVICE_ROLE_KEY
SUPABASE_JWT_SECRET=REPLACE_WITH_SUPABASE_CUSTOM_JWT_SECRET
SUPABASE_JWT_EXPIRES_IN=15m

# OpenAI embeddings.
OPENAI_API_KEY=REPLACE_WITH_OPENAI_API_KEY

# AWS shared region.
AWS_REGION=us-east-1

# S3 uploads.
AWS_S3_BUCKET=remnant-uploads-prod
# Leave empty for the private bucket. Set only when a public CloudFront asset domain is configured.
AWS_S3_PUBLIC_BASE_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# AWS SES transactional email.
AWS_SES_REGION=us-east-1
EMAIL_FROM=noreply@remnantmarket.co

# Escrow.com is disabled at launch because NGN is unsupported.
ESCROW_ENABLED=false
ESCROW_API_EMAIL=
ESCROW_API_KEY=
ESCROW_API_URL=https://api.escrow-sandbox.com/2017-09-01
ESCROW_CURRENCY=usd
ESCROW_ITEM_CATEGORY=other_merchandise
ESCROW_INSPECTION_PERIOD_SECONDS=259200
ESCROW_WEBHOOK_SECRET=
ESCROW_ACCEPT_ON_CONFIRM=false
ESCROW_ALLOW_STUB=false

# Platform settings.
PLATFORM_PAYMENTS_ENABLED=false
PLATFORM_FEE_PERCENTAGE=4
MATCH_SCORE_THRESHOLD=0.72
MATCH_ATTRIBUTE_WEIGHT=0.65
MATCH_SEMANTIC_WEIGHT=0.35
MATCH_MAX_CANDIDATES=200
MATCH_PRICE_TOLERANCE_PERCENT=25
MATCH_REQUIRE_CITY=false
